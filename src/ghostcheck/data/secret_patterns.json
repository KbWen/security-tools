[
    {
        "name": "OpenAI API Key",
        "pattern": "sk-[a-zA-Z0-9]{20,}",
        "severity": "CRITICAL",
        "description": "Potential OpenAI secret key leak"
    },
    {
        "name": "AWS Access Key",
        "pattern": "AKIA[0-9A-Z]{16}",
        "severity": "CRITICAL",
        "description": "AWS IAM Access Key ID"
    },
    {
        "name": "AWS Secret Key",
        "pattern": "(?i)aws_secret_access_key\\s*[:=]\\s*['\"]?[a-zA-Z0-9/+=]{40}['\"]?",
        "severity": "CRITICAL",
        "description": "AWS Secret Access Key"
    },
    {
        "name": "GitHub Token",
        "pattern": "gh[pours]_[a-zA-Z0-9]{36,}",
        "severity": "CRITICAL",
        "description": "GitHub Personal Access Token"
    },
    {
        "name": "Google Cloud API Key",
        "pattern": "AIza[0-9A-Za-z-_]{35}",
        "severity": "CRITICAL",
        "description": "Google Cloud Platform API Key"
    },
    {
        "name": "Slack Webhook URL",
        "pattern": "https://hooks.slack.com/services/T[a-zA-Z0-9_]+/B[a-zA-Z0-9_]+/[a-zA-Z0-9_]+",
        "severity": "HIGH",
        "description": "Slack Incoming Webhook"
    },
    {
        "name": "Stripe Restricted Key",
        "pattern": "rk_live_[0-9a-zA-Z]{24}",
        "severity": "CRITICAL",
        "description": "Stripe Restricted API Key"
    },
    {
        "name": "Database Connection String",
        "pattern": "(mongodb|postgres|mysql|redis)://[a-zA-Z0-9_-]+:[^@]+@[a-zA-Z0-9.-]+",
        "severity": "CRITICAL",
        "description": "Database credentials in connection string"
    },
    {
        "name": "Private Key",
        "pattern": "-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----",
        "severity": "CRITICAL",
        "description": "Private key file content"
    },
    {
        "name": "Generic Secret Key",
        "pattern": "(?i)(secret|key|password|passwd|pwd|token)[:=]\\s*['\"]?[a-zA-Z0-9]{8,}['\"]?",
        "severity": "HIGH",
        "description": "Potential hardcoded secret or password"
    }
]
